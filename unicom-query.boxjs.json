{
  "id": "unicom-query",
  "name": "联通余量查询",
  "author": "@WorkBuddy",
  "icon": "https://raw.githubusercontent.com/Orz-3/mini/master/Color/10010.png",
  "repo": "",
  "apps": [
    {
      "id": "unicom-query",
      "name": "联通余量查询",
      "keys": [
        "@unicom-query.unicom_mobile",
        "@unicom-query.show_detail",
        "@unicom-query.show_remain_percent"
      ],
      "descs_html": [
        "查询联通套餐余量（流量、通话、短信等）",
        "<ol>",
        "<li>配置联通手机号</li>",
        "<li>运行脚本查询余量</li>",
        "</ol>"
      ],
      "settings": [
        {
          "id": "@unicom-query.unicom_mobile",
          "name": "联通手机号",
          "val": "",
          "type": "text",
          "placeholder": "请输入联通手机号",
          "desc": "必填，用于查询余量信息"
        },
        {
          "id": "@unicom-query.show_detail",
          "name": "显示详细信息",
          "val": true,
          "type": "boolean",
          "desc": "是否显示总用量和已用量"
        },
        {
          "id": "@unicom-query.show_remain_percent",
          "name": "显示余量百分比",
          "val": true,
          "type": "boolean",
          "desc": "是否显示余量百分比"
        }
      ]
    }
  ]
}
